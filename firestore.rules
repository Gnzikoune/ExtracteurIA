rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (matches auth.uid)
    // Fields:
    //   - email: string (required) - user's email
    //   - extractionCount: number (required) - number of links extracted
    //   - lastActive: string (optional) - last activity timestamp
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() &&
        request.auth.token.email == "gnzikoune@gmail.com" &&
        request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidUser(data) {
      return hasOnlyAllowedFields(['email', 'extractionCount', 'lastActive', 'role', 'emailStatus', 'persistentId']) &&
             (!('email' in data) || data.email is string) &&
             data.extractionCount is number &&
             data.extractionCount >= 0 &&
             (!('lastActive' in data) || data.lastActive is string) &&
             (!('emailStatus' in data) || data.emailStatus in ['ok', 'invalid']) &&
             (!('role' in data) || data.role in ['admin', 'user']);
    }

    function isValidSettings(data) {
      return hasOnlyAllowedFields(['maxAnonExtractions', 'maxUserExtractions', 'geminiApiKey', 'emailVerifyApiKey', 'updatedAt']) &&
             data.maxAnonExtractions is number && data.maxAnonExtractions >= 0 &&
             data.maxUserExtractions is number && data.maxUserExtractions >= 0 &&
             (!('geminiApiKey' in data) || data.geminiApiKey is string) &&
             (!('emailVerifyApiKey' in data) || data.emailVerifyApiKey is string) &&
             (!('updatedAt' in data) || data.updatedAt is string);
    }

    function isValidExtraction(data) {
      return hasOnlyAllowedFields(['url', 'title', 'description', 'linksCount', 'createdAt', 'userId']) &&
             data.url is string && data.url.size() < 2000 &&
             data.title is string && data.title.size() < 1000 &&
             data.description is string && data.description.size() < 5000 &&
             data.linksCount is number &&
             data.createdAt is string &&
             data.userId is string && data.userId == request.auth.uid;
    }

    function isValidAnalysis(data) {
      return hasOnlyAllowedFields(['url', 'userId', 'isAnonymous', 'createdAt', 'scanType', 'raw', 'metrics', 'ai']) &&
             data.url is string && data.url.size() < 2000 &&
             data.userId is string && data.userId == request.auth.uid &&
             (!('isAnonymous' in data) || data.isAnonymous is bool) &&
             data.createdAt is string &&
             data.scanType is string &&
             data.raw is map &&
             data.metrics is map &&
             (!('ai' in data) || data.ai is map);
    }

    match /users/{userId} {
      // Users can only read their own data, admins can read all
      allow read: if isOwner(userId) || isAdmin();
      
      // Users can create their own profile
      allow create: if isOwner(userId) && 
                    isValidUser(request.resource.data) &&
                    (
                      request.resource.data.extractionCount == 0 || 
                      (request.auth.token.firebase.sign_in_provider == 'anonymous' && request.resource.data.extractionCount <= 2)
                    ) &&
                    (!('role' in request.resource.data) || request.resource.data.role == 'user' || isAdmin());
                    
      // Users can update their own profile, but only increment extractionCount by 1
      allow update: if (isOwner(userId) && 
                    isValidUser(request.resource.data) &&
                    (!('email' in request.resource.data) || !('email' in resource.data) || request.resource.data.email == resource.data.email) &&
                    (request.resource.data.extractionCount == resource.data.extractionCount || 
                     request.resource.data.extractionCount == resource.data.extractionCount + 1) &&
                    (!('role' in request.resource.data) || request.resource.data.role == resource.data.role)) ||
                    (isAdmin() && isValidUser(request.resource.data));

      allow delete: if isAdmin();

      match /extractions/{extractionId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidExtraction(request.resource.data);
        allow update, delete: if isAdmin();
      }
    }

    match /analyses/{analysisId} {
      allow create: if isAuthenticated() && isValidAnalysis(request.resource.data);
      allow update: if (isAuthenticated() && 
                    resource.data.userId == request.auth.uid &&
                    isValidAnalysis(request.resource.data) &&
                    request.resource.data.diff(resource.data).affectedKeys().hasOnly(['ai'])) ||
                    (isAdmin() && isValidAnalysis(request.resource.data));
      allow read: if (isAuthenticated() && resource.data.userId == request.auth.uid) || isAdmin();
      allow delete: if (isAuthenticated() && resource.data.userId == request.auth.uid) || isAdmin();
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin() && isValidSettings(request.resource.data);
    }

    // Persistent tracking for anonymous devices
    match /anonymous_usage/{pid} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && 
                    request.resource.data.count <= 2;
      allow update: if isAuthenticated() && 
                    request.resource.data.count <= 2 &&
                    request.resource.data.count >= resource.data.count;
    }
  }
}
